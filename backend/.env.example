# OrbitPM Backend Environment Variables

# Runtime
DJANGO_ENV=development
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=django-insecure-change-me-for-local-development
DEBUG=True
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
TIME_ZONE=UTC

# Database
# Local development falls back to SQLite when DATABASE_URL and the split
# PostgreSQL variables below are not provided.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orbitpm_db
# DATABASE_NAME=orbitpm_db
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
DATABASE_CONN_MAX_AGE=0
DATABASE_CONN_HEALTH_CHECKS=True
DATABASE_SSL_REQUIRE=False

# CORS and CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_HTTPONLY=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_PROXY_SSL_HEADER=False
USE_X_FORWARDED_HOST=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# JWT
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=False
JWT_UPDATE_LAST_LOGIN=True
JWT_ALGORITHM=HS256
# JWT_SIGNING_KEY=
# JWT_ISSUER=
# JWT_AUDIENCE=
JWT_AUTH_HEADER_TYPES=Bearer
JWT_LEEWAY_SECONDS=0

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=OrbitPM <noreply@localhost>
SERVER_EMAIL=OrbitPM <server@localhost>

# Static, media, and uploads
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media
FILE_UPLOAD_MAX_MEMORY_SIZE=2621440
DATA_UPLOAD_MAX_MEMORY_SIZE=2621440

# Logging
LOG_LEVEL=DEBUG
FILE_LOG_LEVEL=INFO
LOG_FORMATTER=standard
FILE_LOG_FORMATTER=standard
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
